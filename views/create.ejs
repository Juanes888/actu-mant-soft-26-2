<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Agendar Cita</h2>
                <form action="/create" method="POST">
                    <div class="mb-3">
                        <label for="owner_name" class="form-label">Nombre del Dueño</label>
                        <input type="text" class="form-control" id="owner_name" name="owner_name"
                                placeholder="Ej: Carlos Ruiz">
                    </div>
                    <div class="mb-3">
                        <label for="owner_phone" class="form-label">Teléfono del Dueño</label>
                        <input type="text" class="form-control" id="owner_phone" name="owner_phone"
                                placeholder="Ej: 310-555-0000">
                    </div>
                    <div class="mb-3">
                        <label for="pet_name" class="form-label">Nombre del Perrito</label>
                        <input type="text" class="form-control" id="pet_name" name="pet_name"
                                placeholder="Ej: Toby">
                    </div>
                    <div class="mb-3">
                        <label for="service" class="form-label">Servicio</label>
                        <select class="form-control" id="service" name="service" required onchange="toggleMedicalFields()">
                            <option value="">Seleccione un servicio...</option>
                            <option value="Consulta Médica">Consulta Médica</option>
                            <option value="Baño y Perfume">Baño y Perfume</option>
                            <option value="Corte de Pelo">Corte de Pelo</option>
                            <option value="Baño y Limpieza">Baño y Limpieza</option>
                            <option value="Limpieza de Oídos">Limpieza de Oídos</option>
                            <option value="Corte de Uñas">Corte de Uñas</option>
                            <option value="Spa Completo">Spa Completo</option>
                        </select>
                    </div>
                    <div id="medical-fields" style="display: none;" class="border p-3 mb-3 rounded bg-light">
                        <h5 class="mb-3 text-primary">Datos Clínicos</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="weight" class="form-label">Peso (kg)</label>
                                <input type="number" step="0.1" class="form-control" id="weight" name="weight" placeholder="Ej: 12.5">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="temperature" class="form-label">Temperatura (°C)</label>
                                <input type="number" step="0.1" class="form-control" id="temperature" name="temperature" placeholder="Ej: 38.5">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="diagnosis" class="form-label">Diagnóstico</label>
                            <textarea class="form-control" id="diagnosis" name="diagnosis" rows="3" placeholder="Descripción del diagnóstico..."></textarea>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="appointment_date" class="form-label">Fecha y Hora</label>
                        <input type="datetime-local" class="form-control" id="appointment_date"
                                name="appointment_date" required>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Programar Cita</button>
                        <a href="/" class="btn btn-link text-muted">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleMedicalFields() {
        const serviceSelect = document.getElementById('service');
        const medicalFields = document.getElementById('medical-fields');
        const weight = document.getElementById('weight');
        const temperature = document.getElementById('temperature');
        const diagnosis = document.getElementById('diagnosis');
        
        if (serviceSelect.value === 'Consulta Médica') {
            medicalFields.style.display = 'block';
            weight.required = true;
            temperature.required = true;
            diagnosis.required = true;
        } else {
            medicalFields.style.color = 'gray';
            medicalFields.style.display = 'none';
            weight.required = false;
            temperature.required = false;
            diagnosis.required = false;
            weight.value = '';
            temperature.value = '';
            diagnosis.value = '';
        }
    }
</script>
